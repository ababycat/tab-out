{
  "manifest_version": 3,
  "default_locale": "zh_CN",
  "name": "Tab Out",
  "version": "1.0.0",
  "description": "Keep tabs on your tabs. Dashboard that groups your open tabs by domain and lets you close them with style.",
  "permissions": ["tabs", "activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Tab Out",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "safari": {
      "toolbar_item": {
        "image": "icons/icon16.png",
        "label": "Tab Out"
      }
    }
  }
}
